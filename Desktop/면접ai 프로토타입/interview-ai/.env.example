# =============================================
# Database
# =============================================
POSTGRES_USER=interview_user
POSTGRES_PASSWORD=interview_pass
POSTGRES_DB=interview_db
DATABASE_URL=postgresql+asyncpg://interview_user:interview_pass@localhost:5432/interview_db

# =============================================
# Redis / Celery
# =============================================
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# =============================================
# JWT
# =============================================
JWT_SECRET_KEY=your_super_secret_key_change_this_in_production_min_32_chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================
# MinIO (S3-compatible storage)
# =============================================
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET_AUDIO=interview-audio
MINIO_BUCKET_TTS=interview-tts
MINIO_USE_SSL=false

# =============================================
# Storage (local fallback)
# =============================================
STORAGE_PATH=./storage
USE_LOCAL_STORAGE=true

# =============================================
# AI / LLM
# =============================================
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o
# Or use Claude:
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# LLM_PROVIDER=anthropic

# =============================================
# Whisper STT
# =============================================
WHISPER_MODEL=large-v3
# CPU fallback: base or small
WHISPER_MODEL_CPU=base
USE_GPU=false

# =============================================
# Frontend
# =============================================
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# =============================================
# App Settings
# =============================================
ENVIRONMENT=development
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
MAX_INTERVIEW_QUESTIONS=5
MAX_AUDIO_DURATION_SEC=180
