# Copy this file to .env.server on the EC2 host.
# Never commit the real .env.server file.

OPENAI_API_KEY=
OPENAI_GENERATION_MODEL=gpt-5.4-nano
OPENAI_EVAL_MODEL=gpt-4o-mini

ADMIN_PASSWORD=change-this-before-demo
ADMIN_DEMO_UNLOCK=false
COMPATIBILITY_SCORE_GAMMA=1.5

EVALUATE_RATE_LIMIT_WINDOW_MS=60000
EVALUATE_RATE_LIMIT_MAX=10
EVALUATION_LOG_RETENTION_DAYS=14

OPENAI_PREFLIGHT_TIMEOUT_MS=15000
