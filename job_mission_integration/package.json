{
  "name": "jobsim-llm-evaluator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "start": "tsx server.ts",
    "ops:healthcheck": "node scripts/ops-healthcheck.mjs",
    "ops:model-check": "node scripts/ops-model-check.mjs",
    "analyze:compat": "node scripts/analyze-compatibility.mjs",
    "eval:stability": "tsx scripts/eval-stability.ts",
    "eval:stability:ci": "tsx scripts/eval-stability.ts --runs=3 --out=reports/eval-stability-ci.json",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "typecheck": "tsc --noEmit",
    "pipeline:check": "python3 -m py_compile pipeline/*.py"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "openai": "^6.39.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
